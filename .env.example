# Server address/hostname used in .ovpn client configs (remote directive)
# - Inside Docker Compose, use "server" (the service name)
# - For bare-metal or external access, use the server's IP or domain
SERVER_ADDRESS=server

# CA certificate subject fields (Easy-RSA)
EASYRSA_REQ_COUNTRY="US"
EASYRSA_REQ_PROVINCE="California"
EASYRSA_REQ_CITY="San Francisco"
EASYRSA_REQ_ORG="MPS OpenVPN Test"
EASYRSA_REQ_EMAIL="admin@example.com"
EASYRSA_REQ_OU="TestLab"
EASYRSA_KEY_SIZE=2048
EASYRSA_ALGO=rsa
EASYRSA_CA_EXPIRE=3650
EASYRSA_CERT_EXPIRE=3650
